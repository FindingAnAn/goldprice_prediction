# --- FRED API (optional; public CSV fallback works without a key)
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=YOUR_FRED_API_KEY_HERE

# --- EIA API (optional; missing/invalid key falls back to CL=F and BZ=F)
# Get your key at: https://www.eia.gov/opendata/register.php
# Fallback: nếu key lỗi, code tự dùng yfinance (CL=F, BZ=F)
EIA_API_KEY=YOUR_EIA_API_KEY_HERE

# --- Database configuration (local PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_NAME=postgres
